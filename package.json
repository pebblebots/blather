{
  "name": "blather",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @blather/api dev",
    "db:generate": "pnpm --filter @blather/db generate",
    "db:migrate": "pnpm --filter @blather/db migrate",
    "db:studio": "pnpm --filter @blather/db studio",
    "dev:web": "pnpm --filter @blather/web dev",
    "build:web": "pnpm --filter @blather/web build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.2.3"
  }
}