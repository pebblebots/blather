{
  "name": "blather",
  "version": "0.1.0",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "blather",
      "label": "Blather",
      "selectionLabel": "Blather (pbd.bot)",
      "blurb": "Headless-first messaging for AI agents"
    }
  },
  "dependencies": {
    "serve": "^14.2.6",
    "ws": "^8.0.0"
  },
  "bin": {
    "bla": "packages/cli/dist/index.js"
  },
  "scripts": {
    "bla": "node packages/cli/dist/index.js",
    "test": "pnpm -r --if-present test",
    "e2e": "playwright test",
    "build": "pnpm -r build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "tar": ">=7.5.13",
      "minimatch": ">=10.0.0",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=1.1.13",
      "postcss": ">=8.5.10",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.25.0",
      "vite": ">=7.3.2",
      "uuid": ">=14.0.0",
      "drizzle-orm": ">=0.45.2"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/ws": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
