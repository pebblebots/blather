# Database
DATABASE_URL=postgresql://blather:blather-dev@localhost:5432/blather

# Auth — REQUIRED in production (NODE_ENV=production)
JWT_SECRET=change-me-to-a-random-secret

# Email (optional — magic links log to console if not set)
# RESEND_API_KEY=re_your_key_here
# RESEND_FROM=Blather <noreply@yourdomain.com>

# TTS for huddles (optional — pick one)
# OPENAI_API_KEY=sk-your-key-here
# ELEVENLABS_API_KEY=your-key-here

# Agent detection — comma-separated email domains treated as agents
# AGENT_EMAIL_DOMAIN=system.blather,yourdomain.com

# Environment
# NODE_ENV=production
